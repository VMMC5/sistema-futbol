# ============================================================
#  PLANTILLA DE VARIABLES DE ENTORNO
#  Copia este archivo a  .env  y rellena los valores reales:
#      cp .env.example .env
#
#  El archivo .env REAL nunca se sube a GitHub (está en .gitignore).
#  Los secretos reales se comparten por un canal seguro, no por chat.
# ============================================================

# ---------- Base de datos (PostgreSQL) ----------
# En DESARROLLO basta con DB_USER/DB_PASSWORD (un solo usuario, 'postgres').
DB_USER=postgres
DB_PASSWORD=cambia_esta_password
DB_NAME=torneos
DB_HOST=db          # nombre del servicio en docker-compose (no cambiar para Docker)
DB_PORT=5432

# En PRODUCCIÓN se separan dos usuarios (docker-compose.privado.yml):
#   DB_ADMIN_* -> dueño del esquema; lo usan las migraciones de Alembic (DDL).
#   DB_APP_*   -> usuario limitado con el que la API se conecta en runtime;
#                 solo SELECT/INSERT/UPDATE/DELETE, nunca DDL.
# DB_ADMIN_USER=torneos_admin
# DB_ADMIN_PASSWORD=
# DB_APP_USER=torneos_app
# DB_APP_PASSWORD=

# ---------- Servidor público (nginx) ----------
# Direcciones de los backends. En local se dejan vacías (valen los nombres de
# contenedor por defecto). En AWS son la IP privada de la EC2 privada:
# API_1=10.0.2.10:8001
# API_2=10.0.2.10:8002
# WEB_1=10.0.2.10:5000

# ---------- API (FastAPI) ----------
# OBLIGATORIA: la API y el panel web se niegan a arrancar si falta.
# Firma los JWT (API) y la cookie de sesión (Flask).
SECRET_KEY=         # genera una llave larga y aleatoria (p. ej. con: openssl rand -hex 32)
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Rate limiting del login (anti fuerza bruta). Ambas son opcionales:
# RATE_LIMIT_ENABLED=false lo desactiva; LOGIN_RATE_LIMIT ajusta el tope por IP.
# RATE_LIMIT_ENABLED=true
# LOGIN_RATE_LIMIT=20/minute

# ---------- Entorno ----------
# "production" endurece el comportamiento: el seed (python -m app.seed) aborta
# para no crear usuarios demo con contraseñas conocidas.
# En docker-compose.privado.yml ya viene puesto a production.
APP_ENV=development

# ---------- Seed (datos demo) ----------
# Solo para desarrollo. Si no se definen, se usan las contraseñas demo por
# defecto (admin1234 / demo1234), que NUNCA deben llegar a producción.
# SEED_PASSWORD_SUPERADMIN=
# SEED_PASSWORD_ENTRENADOR=
# SEED_PASSWORD_ARBITRO=
# SEED_PASSWORD_JUGADOR=
# SEED_PASSWORD_PLANTEL=           # jugadores de las plantillas demo
# SEED_ALLOW_IN_PROD=true          # escape consciente: exige TODAS las de arriba

# ---------- Panel web (Flask) ----------
API_URL=http://api:8000   # cómo el panel encuentra a la API dentro de Docker

# ---------- Pagos (rellenar cuando integren la pasarela) ----------
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
