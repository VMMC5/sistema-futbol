# ===== Secretos / entorno =====
# Se ignora CUALQUIER variante de .env (.env.local, .env.produccion.local, ...):
# levantar-local.sh genera .env.produccion.local copiando el .env real, con
# SECRET_KEY y las contraseñas de la base dentro. Sin este patrón, un `git add -A`
# despistado lo subiría al repositorio.
.env
.env.*
# La plantilla SÍ se versiona: no tiene secretos, solo los nombres de las variables.
!.env.example
*.pem
*.key

# Certificados y material de Let's Encrypt (contienen la clave privada).
infra/letsencrypt/

# ===== Documentos subidos =====
api/uploads/

# ===== Python (api / web) =====
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ===== Node / React Native / Expo (mobile) =====
node_modules/
.expo/
.expo-shared/
dist/
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# ===== Docker =====
# (los volúmenes viven en Docker, no en el repo; nada que ignorar aquí normalmente)

# ===== Editores / SO =====
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# ===== Herramientas locales (Claude Code) =====
.claude/

# Artefactos de Windows (Mark of the Web) al copiar archivos desde el host
*:Zone.Identifier
